# Required
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
GOOGLE_API_KEY=your_google_cloud_api_key_with_tts_enabled

# Voice (optional) — any Google Cloud TTS voice name
TTS_VOICE=th-TH-Chirp3-HD-Achernar

# Usage metering (optional) — leave blank to disable persistent quota tracking
SUPABASE_URL=
SUPABASE_KEY=
TTS_MONTHLY_FREE_CHARS=1000000

# Tuning (optional)
COLLECT_WINDOW_SECONDS=5
TTS_PART_SIZE=1950
PORT=8443
